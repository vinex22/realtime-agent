        </mxCell>
        <mxCell id="server-b2a" value="→ browser_to_azure()&#xa;Forwards mic audio to Azure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="280" width="220" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="server-a2b" value="← azure_to_browser()&#xa;Forwards model audio to browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="340" width="220" height="45" as="geometry"/>
