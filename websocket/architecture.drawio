        <mxCell id="server-ws" value="WS /ws&#xa;Accepts browser WebSocket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
