# Azure OpenAI / Foundry resource name (the "<resource>" in https://<resource>.openai.azure.com)
AZURE_RESOURCE=<your-resource-name>

# Realtime model deployment name (must be one of the supported realtime models,
# e.g. gpt-4o-mini-realtime-preview, gpt-4o-realtime-preview, gpt-realtime,
# gpt-realtime-mini, gpt-realtime-1.5). Deploy it in East US 2 or Sweden Central.
REALTIME_DEPLOYMENT=gpt-realtime-1.5

# Optional: voice for audio output (alloy, ash, ballad, coral, echo, sage,
# shimmer, verse, marin)
REALTIME_VOICE=marin

# Optional: system prompt
REALTIME_INSTRUCTIONS=You are a helpful, concise voice assistant.

# WebRTC token service port
PORT=5000

# WebSocket proxy port
WS_PORT=5001

# Deployed WebRTC webapp URL (used by inspect_session.py)
WEBAPP_URL=https://<your-webrtc-app>.azurewebsites.net

# Azure identity (used by DefaultAzureCredential / az CLI)
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
